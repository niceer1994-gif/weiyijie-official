---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Weiyijie Bio - Premium Plant Extracts, Cosmetic & Food Ingredients", description = "10+ years supplier of high-quality plant extracts, cosmetic raw materials, and food additives. FDA/REACH/GMP certified, small MOQ supported, global delivery." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/images/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="plant extracts, cosmetic ingredients, food additives, bulk supplier, GMP certified, FDA approved" />
	</head>
	<body class="font-sans text-gray-800">
		<Header />
		<slot />
		<Footer />
	</body>
</html>
