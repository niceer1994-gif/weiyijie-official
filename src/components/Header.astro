---
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img 
          src="/images/logo.png" 
          alt="Weiyijie Bio Logo" 
          class="h-12"
          onError={(e) => e.target.src = 'https://placehold.co/200x80/ffffff/1e40af?text=WEIYIJIE'}
        />
      </a>
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="font-medium text-gray-700 hover:text-blue-600 transition-all">Home</a>
        <!-- Products Dropdown -->
        <div class="relative group">
          <button class="font-medium text-gray-700 hover:text-blue-600 transition-all flex items-center gap-1">
            Products ▼
          </button>
          <div class="absolute right-0 top-full mt-2 w-64 bg-white shadow-lg rounded-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <a href="/category/plant-extracts" class="block px-6 py-3 hover:bg-gray-50 text-gray-700 hover:text-blue-600 transition-all">
              Plant Extracts
            </a>
            <a href="/category/cosmetic-ingredients" class="block px-6 py-3 hover:bg-gray-50 text-gray-700 hover:text-blue-600 transition-all">
              Cosmetic Raw Materials
            </a>
            <a href="/category/food-additives" class="block px-6 py-3 hover:bg-gray-50 text-gray-700 hover:text-blue-600 transition-all">
              Food Additives
            </a>
          </div>
        </div>
        <a href="/#about" class="font-medium text-gray-700 hover:text-blue-600 transition-all">About Us</a>
        <a href="/#faq" class="font-medium text-gray-700 hover:text-blue-600 transition-all">FAQ</a>
        <a href="/#contact" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2 rounded-lg transition-all">
          Contact Us
        </a>
      </nav>
      <!-- Mobile Menu Button -->
      <button class="md:hidden text-gray-700 text-2xl">☰</button>
    </div>
  </div>
</header>
