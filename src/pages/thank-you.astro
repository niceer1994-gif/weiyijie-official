---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Thank You - Weiyijie Bio"
  description="Thank you for your inquiry. We will contact you within 24 hours."
>
  <section class="py-24 bg-gray-50 min-h-[70vh] flex items-center">
    <div class="container mx-auto px-6 text-center max-w-2xl">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-4xl mx-auto mb-6">✅</div>
      <h1 class="text-[clamp(1.8rem,4vw,2.5rem)] font-bold text-gray-900 mb-4">Thank You for Your Inquiry!</h1>
      <p class="text-gray-600 mb-8 text-lg">We have received your message successfully. Our sales team will contact you within 24 hours with detailed product information and quotation.</p>
      <p class="text-gray-600 mb-12">If you need immediate assistance, please contact us directly at <a href="mailto:sales@weiyijiebio.com" class="text-green-600 font-medium hover:underline">sales@weiyijiebio.com</a> or WhatsApp +86 138 0000 0000.</p>
      <a href="/" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all">
        Back to Homepage
      </a>
    </div>
  </section>
</Layout>
