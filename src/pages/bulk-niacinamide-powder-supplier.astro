---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Bulk Niacinamide Powder Supplier | 99% Purity Cosmetic Grade | Weiyijie Bio"
  description="High-quality bulk niacinamide powder (vitamin B3) supplier. 99% purity, cosmetic grade, complete certifications, 1kg MOQ, fast global delivery. Request free sample and quote today."
>
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-[clamp(2rem,4vw,3rem)] font-bold text-gray-900 mb-4">Bulk Niacinamide Powder (Vitamin B3)</h1>
        <p class="text-gray-600 text-lg">High-quality 99% pure cosmetic grade niacinamide powder for skincare formulations. Complete certifications, competitive pricing, 1kg MOQ supported.</p>
      </div>

      <div class="bg-white rounded-xl shadow-md p-8 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Product Specifications</h2>
            <table class="w-full">
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Product Name</td>
                <td class="py-3 text-gray-600">Niacinamide (Vitamin B3, Nicotinamide)</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Purity</td>
                <td class="py-3 text-gray-600">99% minimum (HPLC tested)</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Appearance</td>
                <td class="py-3 text-gray-600">White crystalline powder</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">CAS Number</td>
                <td class="py-3 text-gray-600">98-92-0</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Molecular Formula</td>
                <td class="py-3 text-gray-600">C6H6N2O</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Solubility</td>
                <td class="py-3 text-gray-600">Soluble in water and glycerin, slightly soluble in ethanol</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Melting Point</td>
                <td class="py-3 text-gray-600">128-131°C</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 font-medium text-gray-900">Grade</td>
                <td class="py-3 text-gray-600">Cosmetic Grade / Food Grade available</td>
              </tr>
            </table>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Key Benefits for Skincare</h2>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">✨</span>
              <span class="text-gray-700"><strong>Skin brightening:</strong> Inhibits melanin transfer to keratinocytes, reduces hyperpigmentation and evens skin tone</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">🧴</span>
              <span class="text-gray-700"><strong>Barrier repair:</strong> Increases ceramide synthesis, improves skin barrier function, reduces transepidermal water loss</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">🕳️</span>
              <span class="text-gray-700"><strong>Pore minimizing:</strong> Regulates sebum production, reduces pore size and prevents breakouts</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">🌿</span>
              <span class="text-gray-700"><strong>Anti-inflammatory:</strong> Soothes irritated skin, reduces redness and sensitivity</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">⏳</span>
              <span class="text-gray-700"><strong>Anti-aging:</strong> Stimulates collagen production, reduces fine lines and wrinkles</span>
            </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Applications</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">🧴</span>
            <h3 class="font-bold text-gray-900 mb-2">Serums & Essences</h3>
            <p class="text-gray-600 text-sm">2-5% concentration for brightening and barrier repair serums</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">🥛</span>
            <h3 class="font-bold text-gray-900 mb-2">Moisturizers</h3>
            <p class="text-gray-600 text-sm">1-3% concentration for daily moisturizers and lotions</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">🧼</span>
            <h3 class="font-bold text-gray-900 mb-2">Toner</h3>
            <p class="text-gray-600 text-sm">0.5-2% concentration for exfoliating and brightening toners</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">🎭</span>
            <h3 class="font-bold text-gray-900 mb-2">Face Masks</h3>
            <p class="text-gray-600 text-sm">1-5% concentration for brightening and soothing masks</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">☀️</span>
            <h3 class="font-bold text-gray-900 mb-2">Sun Care</h3>
            <p class="text-gray-600 text-sm">1-3% concentration for after-sun repair and daily sun protection products</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-3xl mb-3 block">🍎</span>
            <h3 class="font-bold text-gray-900 mb-2">Food Supplements</h3>
            <p class="text-gray-600 text-sm">Food grade for oral supplements, skin health supplements</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Packaging & Pricing</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Packaging Options</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">📦</span>
                <span class="text-gray-700>1kg/aluminum foil bag, food grade, sealed and moisture-proof</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">📦</span>
                <span class="text-gray-700>25kg/fiber drum, double plastic bag inside</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">🎁</span>
                <span class="text-gray-700>Custom packaging available (private label, custom sizes, printing logo)</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Bulk Pricing (FOB China)</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">💰</span>
                <span class="text-gray-700>1-10kg: $25/kg</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">💰</span>
                <span class="text-gray-700>10-100kg: $22/kg</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1 text-xl">💰</span>
                <span class="text-gray-700>100kg+: $18/kg</span>
              </li>
            </ul>
            <p class="text-gray-500 text-sm mt-2">Price negotiable for large volume orders. Contact us for latest pricing.</p>
          </div>
        </div>
      </div>

      <div class="bg-green-50 rounded-xl p-8 border border-green-200 mt-12">
        <h3 class="text-xl font-bold text-green-800 mb-4">Why Buy Niacinamide from Weiyijie Bio?</h3>
        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✅</span>
            <span class="text-gray-700">99% high purity, HPLC tested, no heavy metals or contaminants</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✅</span>
            <span class="text-gray-700">Complete certifications: COA, SDS, TDS, FDA/REACH compliant, Halal/Kosher certified</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✅</span>
            <span class="text-gray-700">1kg MOQ, perfect for small batch testing and production</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✅</span>
            <span class="text-gray-700">Fast delivery: 3-5 days for stock, 7-15 days global shipping</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✅</span>
            <span class="text-gray-700">Free samples available for quality testing before bulk order</span>
          </li>
        </ul>
        <div class="text-center">
          <a href="/#contact" class="bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all mr-4">
            Request Free Sample
          </a>
          <a href="/#contact" class="bg-white border-2 border-green-600 hover:bg-green-50 text-green-600 font-semibold px-8 py-3 rounded-lg inline-block transition-all">
            Get Bulk Quote Now
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
