---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero Section: 核心转化区 -->
  <section class="relative h-[90vh] bg-gradient-to-r from-green-900/80 to-green-800/80 flex items-center">
    <img 
      src="https://images.unsplash.com/photo-1586788224331-947f68671cf1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" 
      alt="Premium plant extract production process" 
      class="absolute inset-0 w-full h-full object-cover -z-10"
    />
    <div class="container mx-auto px-6">
      <div class="max-w-4xl">
        <p class="text-green-200 font-semibold text-lg mb-3 uppercase tracking-wider">Trusted supplier since 2014</p>
        <h1 class="text-[clamp(2.5rem,5vw,4rem)] font-bold text-white mb-4 leading-tight">
          Wholesale Plant Extracts, Cosmetic Ingredients & Food Additives<br>For Manufacturers, Brands & Formulators
        </h1>
        <p class="text-[clamp(1rem,2vw,1.25rem)] text-green-50 mb-8 max-w-3xl">
          10+ years experience supplying high-quality natural ingredients. FDA/REACH/GMP certified, 1kg MOQ supported, 7-15 days global delivery, 24h response guarantee.
        </p>
        <!-- 核心CTA按钮组 -->
        <div class="flex flex-wrap gap-4 mb-8">
          <a href="#contact" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg transition-all transform hover:scale-105 shadow-lg">
            📥 Get Bulk Quote in 24h
          </a>
          <a href="#contact" class="bg-white hover:bg-gray-100 text-green-800 font-semibold px-8 py-3 rounded-lg transition-all transform hover:scale-105 shadow-lg">
            🧪 Request Free Sample / COA
          </a>
        </div>
        <!-- 分人群入口 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-2xl">
          <a href="/category/cosmetic-ingredients" class="bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white p-4 rounded-lg transition-all text-center border border-white/20">
            <p class="font-semibold">For Cosmetic Brands →</p>
            <p class="text-sm text-green-100">High-purity active ingredients</p>
          </a>
          <a href="/category/plant-extracts" class="bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white p-4 rounded-lg transition-all text-center border border-white/20">
            <p class="font-semibold">For Supplement Factories →</p>
            <p class="text-sm text-green-100">Standardized plant extracts</p>
          </a>
          <a href="/category/food-additives" class="bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white p-4 rounded-lg transition-all text-center border border-white/20">
            <p class="font-semibold">For Food & Beverage →</p>
            <p class="text-sm text-green-100">Natural food grade additives</p>
          </a>
        </div>
      </div>
    </div>
    <!-- 悬浮询盘按钮 -->
    <a href="#contact" class="fixed bottom-8 right-8 bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-full shadow-lg font-semibold z-50 transition-all hover:scale-110">
      📩 Get Instant Quote
    </a>
  </section>

  <!-- 信任证据栏 -->
  <section class="py-6 bg-gray-100">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-bold text-green-600 mb-1">10+</p>
          <p class="text-gray-600 text-sm">Years Industry Experience</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-green-600 mb-1">500+</p>
          <p class="text-gray-600 text-sm">Global Happy Customers</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-green-600 mb-1">30+</p>
          <p class="text-gray-600 text-sm">Countries Served</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-green-600 mb-1">24h</p>
          <p class="text-gray-600 text-sm">Average Response Time</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Categories Section: 提前的产品分类导航 -->
  <section id="products" class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">Our Product Categories</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Select from our wide range of high-quality natural ingredients, all certified and available in small batches.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <!-- 分类卡片1 -->
        <a href="/category/plant-extracts" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4">
            <img 
              src="/images/plant-extracts.jpg" 
              alt="Plant Extracts" 
              class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
            />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Plant Extracts</h3>
          <p class="text-gray-600 mb-4">Pure natural plant extracts with high active ingredient content, suitable for cosmetics, health products and food.</p>
          <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Products →</span>
        </a>
        <!-- 分类卡片2 -->
        <a href="/category/cosmetic-ingredients" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4">
            <img 
              src="/images/cosmetic-ingredients.jpg" 
              alt="Cosmetic Raw Materials" 
              class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
            />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Cosmetic Raw Materials</h3>
          <p class="text-gray-600 mb-4">High-purity cosmetic active ingredients, including moisturizers, antioxidants, whitening agents, etc.</p>
          <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Products →</span>
        </a>
        <!-- 分类卡片3 -->
        <a href="/category/food-additives" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4">
            <img 
              src="/images/food-additives.jpg" 
              alt="Food Additives" 
              class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
            />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Food Additives</h3>
          <p class="text-gray-600 mb-4">Natural food additives, including preservatives, flavor enhancers, nutritional fortifiers, etc., all meet food safety standards.</p>
          <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Products →</span>
        </a>
      </div>

      <!-- 主推产品展示 -->
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">Most Popular Products</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Our best-selling ingredients trusted by customers worldwide, available in small MOQ with full certifications.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- 产品1：3-O-乙基抗坏血酸 -->
        <a href="/product/high-quality-pure-natural-vitamin-c-powder-for-food-and-beverage" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">🍊</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">3-O-Ethyl Ascorbic Acid</h3>
          <p class="text-gray-600 mb-3">Stable vitamin C derivative for skin brightening, 99% purity, cosmetic grade.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
        <!-- 产品2：壬二酸 -->
        <a href="#" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">🧴</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Azelaic Acid 99%</h3>
          <p class="text-gray-600 mb-3">For acne treatment and skin brightening, cosmetic grade, complete certifications.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
        <!-- 产品3：透明质酸钠 -->
        <a href="/product/99-hyaluronic-acid-powder-sodium-hyaluronate-for-cosmetics-material" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">💧</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Sodium Hyaluronate</h3>
          <p class="text-gray-600 mb-3">Hyaluronic acid powder with different molecular weights for moisturizing.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
        <!-- 产品4：葡萄籽提取物 -->
        <a href="/product/high-quality-grape-seed-extract-95-proanthocyanidins" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">🍇</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Grape Seed Extract 95% OPC</h3>
          <p class="text-gray-600 mb-3">Powerful antioxidant for supplements and cosmetics, GMP certified.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
        <!-- 产品5：姜黄素 -->
        <a href="/product/premium-turmeric-extract-with-95-curcuminoids" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">🌿</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Curcumin 95%</h3>
          <p class="text-gray-600 mb-3">Turmeric extract for anti-inflammatory supplements, food grade.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
        <!-- 产品6：甜菊糖苷 -->
        <a href="/product/high-quality-bulk-sweetener-stevioside-powder" class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all p-6 group">
          <div class="h-48 rounded-lg overflow-hidden mb-4 bg-gray-100 flex items-center justify-center">
            <span class="text-5xl">🍬</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Stevioside 90%~99%</h3>
          <p class="text-gray-600 mb-3">Natural zero-calorie sweetener for food and beverage, Kosher/Halal certified.</p>
          <div class="flex items-center justify-between">
            <span class="text-green-600 font-semibold">MOQ: 1kg</span>
            <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
          </div>
        </a>
      </div>
      <div class="text-center mt-12">
        <a href="#contact" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all">
          Request Quote for These Products
        </a>
      </div>
    </div>
  </section>

  <!-- Why Work With Us Section + 客户logo墙 -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">Why Choose Weiyijie Bio</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">We have been trusted by 500+ customers from 30+ countries for over 10 years.</p>
      </div>

      <!-- 优势板块 -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 rounded-xl hover:bg-green-50 transition-all">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-2xl font-bold mx-auto mb-4">✅</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Complete Certifications Available</h3>
          <p class="text-gray-600">We can provide cooperative factory's FDA, REACH, GMP, Kosher, Halal certificates, all products meet international standards.</p>
        </div>
        <div class="text-center p-6 rounded-xl hover:bg-green-50 transition-all">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-2xl font-bold mx-auto mb-4">📦</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Small MOQ Supported</h3>
          <p class="text-gray-600">Minimum order quantity starting from 1kg, perfect for small businesses and R&D testing.</p>
        </div>
        <div class="text-center p-6 rounded-xl hover:bg-green-50 transition-all">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-2xl font-bold mx-auto mb-4">⚡</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Fast Delivery</h3>
          <p class="text-gray-600">7-15 days global delivery, with DHL/FedEx/UPS express shipping available.</p>
        </div>
        <div class="text-center p-6 rounded-xl hover:bg-green-50 transition-all">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-2xl font-bold mx-auto mb-4">🔬</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Customization Service</h3>
          <p class="text-gray-600">Support custom extraction ratio, formula development, and packaging design according to your needs.</p>
        </div>
      </div>
      <!-- 客户评价 -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
          <div class="flex items-center mb-4">
            <span class="text-yellow-400 text-lg">⭐⭐⭐⭐⭐</span>
          </div>
          <p class="text-gray-700 mb-4 italic">"We have been cooperating with Weiyijie for 5 years, their product quality is stable, and the delivery is always on time. Highly recommended!"</p>
          <p class="font-semibold text-gray-900">— John Smith, Purchasing Manager at US Cosmetics Brand</p>
        </div>
        <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
          <div class="flex items-center mb-4">
            <span class="text-yellow-400 text-lg">⭐⭐⭐⭐⭐</span>
          </div>
          <p class="text-gray-700 mb-4 italic">"The small MOQ service is perfect for our startup, we tested 3 samples first, then placed a bulk order. Great support team!"</p>
          <p class="font-semibold text-gray-900">— Marie Dubois, Founder of French Natural Skincare Brand</p>
        </div>
        <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
          <div class="flex items-center mb-4">
            <span class="text-yellow-400 text-lg">⭐⭐⭐⭐⭐</span>
          </div>
          <p class="text-gray-700 mb-4 italic">"All their products have complete certification documents, which saved us a lot of time in customs clearance. Very professional supplier."</p>
          <p class="font-semibold text-gray-900">— Li Wei, Operations Director at Singapore Food Company</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Us Section: 工厂实拍+团队介绍 -->
  <section id="about" class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">About Weiyijie Bio</h2>
          <p class="text-gray-600 mb-6">Established in 2014, Weiyijie Bio is a professional supplier of natural ingredients, with core team having 10+ years of industry experience in plant extracts, cosmetic raw materials and food additives.</p>
          <p class="text-gray-600 mb-8">We strictly select high-quality GMP certified cooperative factories, have a strict quality control system, and can provide complete factory certification documents including FDA, REACH, Kosher, Halal, etc., to ensure that every batch of products meets international standards.</p>
          <!-- 核心优势 -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">✅</span>
              <div>
                <h4 class="font-bold text-gray-900">10+ Years Industry Experience</h4>
                <p class="text-gray-600 text-sm">Core team has deep understanding of product quality standards and global market demand</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">✅</span>
              <div>
                <h4 class="font-bold text-gray-900">Strict Quality Control</h4>
                <p class="text-gray-600 text-sm">Each batch of products is inspected before shipment to ensure quality stability</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">✅</span>
              <div>
                <h4 class="font-bold text-gray-900">Complete Certifications Available</h4>
                <p class="text-gray-600 text-sm">We can provide cooperative factory's FDA/REACH/GMP/Kosher/Halal certificates</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-500 mt-1 text-xl">✅</span>
              <div>
                <h4 class="font-bold text-gray-900">Small MOQ Supported</h4>
                <p class="text-gray-600 text-sm">Minimum order from 1kg, perfect for small businesses and R&D testing</p>
              </div>
            </div>
          </div>
          <a href="#contact" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all">
            Learn More About Us
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4">
          <iframe 
            width="100%" 
            src="https://www.youtube.com/embed/YJgrpmq9YEU?autoplay=1&mute=1&loop=1&playlist=YJgrpmq9YEU&controls=1" 
            title="Weiyijie Bio Production Line" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            class="rounded-xl shadow-lg h-96 w-full object-cover"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section: 突出物流、售后、定制化 -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Find answers to the most common questions our customers ask.</p>
      </div>
      <div class="max-w-3xl mx-auto space-y-6">
        <!-- 问题1: MOQ -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">What is your minimum order quantity (MOQ)?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">Our MOQ is 1kg for most products, which is very suitable for small businesses, R&D testing and new product development. For bulk orders, we offer very competitive discounts.</p>
            </div>
          </details>
        </div>
        <!-- 问题2: 物流 -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">What shipping methods do you offer and how long does delivery take?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">We offer multiple shipping options:
                <ul class="list-disc pl-5 mt-2 space-y-1">
                  <li>Express (DHL/FedEx/UPS): 3-7 days delivery, suitable for small orders</li>
                  <li>Air freight: 7-10 days delivery, suitable for medium orders</li>
                  <li>Sea freight: 15-30 days delivery, most cost-effective for bulk orders</li>
                </ul>
                We will provide tracking number for all orders, and we handle all customs clearance documents for you.
              </p>
            </div>
          </details>
        </div>
        <!-- 问题3: 认证 -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">What certifications do your products have?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">We can provide complete certification documents from our cooperative factories, including FDA, REACH, GMP, Kosher, Halal, ISO 9001, etc. All required documents will be provided for your customs clearance and product registration.</p>
            </div>
          </details>
        </div>
        <!-- 问题4: 定制化 -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">Do you offer customization services?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">Yes, we provide full customization services:
                <ul class="list-disc pl-5 mt-2 space-y-1">
                  <li>Custom extraction ratio and active ingredient content</li>
                  <li>Custom formula development according to your product needs</li>
                  <li>Custom packaging design and labeling</li>
                  <li>Customized product testing reports</li>
                </ul>
                Our R&D team will work with you to develop the perfect product for your market.
              </p>
            </div>
          </details>
        </div>
        <!-- 问题5: 售后 -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">What is your after-sales policy?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">We offer a 100% satisfaction guarantee:
                <ul class="list-disc pl-5 mt-2 space-y-1">
                  <li>If the product quality does not meet the agreed standards, we will refund or replace the product for free</li>
                  <li>We provide 24/7 technical support and after-sales service</li>
                  <li>We can provide free samples for testing before you place a bulk order</li>
                  <li>We will follow up on the usage effect of each batch of products and provide improvement suggestions</li>
                </ul>
              </p>
            </div>
          </details>
        </div>
        <!-- 问题6: 付款方式 -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-all">
              <h3 class="font-semibold text-lg text-gray-900">What payment methods do you accept?</h3>
              <span class="text-green-500 group-open:rotate-180 transition-all">▼</span>
            </summary>
            <div class="p-6 bg-white">
              <p class="text-gray-600">We accept multiple secure payment methods: T/T bank transfer, PayPal, Western Union, Alibaba Trade Assurance, L/C, etc. For new customers, we recommend Alibaba Trade Assurance to protect your payment security.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 bg-green-900 text-white">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold mb-4">Get In Touch With Us</h2>
          <p class="text-green-100 mb-8 max-w-xl">If you have any questions about our products, or want to request a quote or sample, please fill out the form below or contact us directly. We will reply to you within 24 hours.</p>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-green-800 rounded-full flex items-center justify-center">📍</div>
              <p class="text-green-100">No. 16, Fengqi West Road, Chang'an District, Xi'an, Shaanxi, China</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-green-800 rounded-full flex items-center justify-center">📧</div>
              <p class="text-green-100">sales@weiyijiebio.com</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-green-800 rounded-full flex items-center justify-center">📱</div>
              <p class="text-green-100">+86 19909215700 (WhatsApp/WeChat same number)</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-8 text-gray-800 shadow-xl">
          <form action="https://formsubmit.co/sales@weiyijiebio.com" method="POST">
            <!-- Anti-spam honeypot field -->
            <input type="text" name="_honey" style="display: none;">
            <!-- Redirect after submit -->
            <input type="hidden" name="_next" value="https://weiyijiebio.com/thank-you">
            <!-- Disable captcha -->
            <input type="hidden" name="_captcha" value="false">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                <input type="text" name="first_name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                <input type="text" name="last_name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
                <input type="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Country/Region *</label>
                <input type="text" name="country" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="e.g. United States, Germany">
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Company Name</label>
                <input type="text" name="company" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Company Type *</label>
                <select name="company_type" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                  <option value="">Select your business type</option>
                  <option value="cosmetic_brand">Cosmetic Brand/Manufacturer</option>
                  <option value="supplement_manufacturer">Supplement/Health Product Manufacturer</option>
                  <option value="food_beverage_manufacturer">Food & Beverage Manufacturer</option>
                  <option value="trading_distributor">Trading Company/Distributor</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Product Interest *</label>
                <select name="product_interest" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                  <option value="">Select product category</option>
                  <option value="plant-extracts">Plant Extracts</option>
                  <option value="cosmetic-ingredients">Cosmetic Raw Materials</option>
                  <option value="food-additives">Food Additives</option>
                  <option value="multiple">Multiple Categories</option>
                  <option value="custom">Custom Product</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Required Quantity</label>
                <input type="text" name="quantity" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="e.g. 100kg, 500kg, 1MT">
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Target Application</label>
                <input type="text" name="application" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="e.g. Skin care serum, sports supplements, energy drinks">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Certifications Required</label>
                <input type="text" name="certifications" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="e.g. FDA, REACH, Kosher, Halal, Organic">
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-1">What do you need? *</label>
              <div class="flex flex-wrap gap-3 mb-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="need[]" value="quote" class="h-4 w-4 text-green-600">
                  <span class="text-sm text-gray-700">Bulk Price Quote</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="need[]" value="sample" class="h-4 w-4 text-green-600">
                  <span class="text-sm text-gray-700">Free Sample</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="need[]" value="coa" class="h-4 w-4 text-green-600">
                  <span class="text-sm text-gray-700">COA / Certification Documents</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="need[]" value="custom" class="h-4 w-4 text-green-600">
                  <span class="text-sm text-gray-700">Custom Specification/Packaging</span>
                </label>
              </div>
              <textarea name="message" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Please tell us any other requirements, purity needs, etc."></textarea>
            </div>
            <button type="submit" class="w-full bg-green-500 hover:bg-green-600 text-white font-semibold py-3 rounded-lg transition-all text-lg">
              Send Request Now
            </button>
            <p class="text-xs text-gray-500 text-center mt-3">We will reply to you within 24 hours on working days.</p>
          </form>
        </div>
      </div>
    </div>
  </section>


</Layout>
