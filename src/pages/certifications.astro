---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Certifications - Weiyijie Bio">
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h1 class="text-[clamp(2rem,4vw,3rem)] font-bold text-gray-900 mb-4">Our Certifications</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">All our products are produced in GMP certified factories and meet international quality standards, with complete certification documents available for customs clearance and product registration.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- 证书卡片1：FDA -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">🏥</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">FDA Certification</h3>
          <p class="text-gray-600 mb-4">Our products meet the US Food and Drug Administration safety standards, suitable for import and sale in the US market.</p>
        </div>
        <!-- 证书卡片2：REACH -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">🇪🇺</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">REACH Compliance</h3>
          <p class="text-gray-600 mb-4">All ingredients comply with EU REACH regulations, with all required registration documents available for EU market access.</p>
        </div>
        <!-- 证书卡片3：GMP -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">✅</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">GMP Certified</h3>
          <p class="text-gray-600 mb-4">All cooperative factories follow Good Manufacturing Practice standards, ensuring consistent product quality and safety.</p>
        </div>
        <!-- 证书卡片4：Kosher -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">✡️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Kosher Certified</h3>
          <p class="text-gray-600 mb-4">Our products meet Jewish dietary law requirements, suitable for sale in kosher markets worldwide.</p>
        </div>
        <!-- 证书卡片5：Halal -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">☪️</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Halal Certified</h3>
          <p class="text-gray-600 mb-4">All ingredients meet Islamic halal standards, suitable for sale in Muslim markets globally.</p>
        </div>
        <!-- 证书卡片6：ISO 9001 -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-all">
          <div class="h-48 flex items-center justify-center mb-4 bg-gray-50 rounded-lg">
            <span class="text-6xl">📋</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">ISO 9001 Certified</h3>
          <p class="text-gray-600 mb-4">Our quality management system meets ISO 9001 international standards, ensuring consistent product quality.</p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-6">Need specific certification documents for your order? Contact our sales team and we will provide the full set of documents within 24 hours.</p>
        <a href="#contact" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all">
          Request Certification Documents
        </a>
      </div>
    </div>
  </section>
</Layout>
