---
import Layout from '../../layouts/Layout.astro';
import productData from '../../data/products.json';

const products = productData.products.filter(p => p.category === '化妆品原料');
---

<Layout 
  title="Cosmetic Raw Materials - Weiyijie Bio | Wholesale Cosmetic Ingredients Supplier"
  description="High quality cosmetic raw materials wholesale supplier. We offer pure cosmetic active ingredients including moisturizers, antioxidants, whitening agents with full certifications. Small MOQ supported."
>
  <!-- 页面头部 -->
  <section class="py-12 bg-gradient-to-r from-pink-900 to-pink-800 text-white">
    <div class="container mx-auto px-6">
      <h1 class="text-[clamp(2rem,4vw,3rem)] font-bold mb-4">Cosmetic Raw Materials</h1>
      <p class="text-pink-100 max-w-3xl text-lg">We provide a full range of high-purity cosmetic active ingredients, suitable for all kinds of skincare, hair care and makeup products. All materials meet international cosmetic safety standards, FDA and REACH certified.</p>
      <p class="text-pink-200 mt-2 font-medium">Total products: {products.length}</p>
    </div>
  </section>

  <!-- 产品列表 -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map(product => (
          <a href={`/product/${product.slug}`} class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all group overflow-hidden">
            <div class="h-56 overflow-hidden">
              <img 
                src={product.image} 
                alt={product.name} 
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
                onError={(e) => e.target.src = 'https://placehold.co/600x400/ffffff/be185d?text=WEIYIJIE+Product'}
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">{product.name}</h3>
              <p class="text-gray-600 mb-4 line-clamp-3">{product.description}</p>
              <div class="flex justify-between items-center">
                <span class="text-pink-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
                <span class="text-sm bg-pink-100 text-pink-800 px-3 py-1 rounded-full">In Stock</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 咨询板块 -->
  <section class="py-12 bg-pink-50">
    <div class="container mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Need Custom Cosmetic Ingredients or Formula Development?</h2>
      <p class="text-gray-600 mb-8 max-w-2xl mx-auto">We support custom ingredient specifications and formula development services. Contact us today to get a free quote and sample.</p>
      <a href="/#contact" class="bg-pink-500 hover:bg-pink-600 text-white font-semibold px-8 py-3 rounded-lg inline-block transition-all">
        Request Custom Quote
      </a>
    </div>
  </section>
</Layout>
