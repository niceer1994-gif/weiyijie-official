---
import Layout from '../../layouts/Layout.astro';
import productData from '../../data/products.json';

// 静态生成所有产品页面
export async function getStaticPaths() {
  return productData.products.map(product => ({
    params: { slug: product.slug }
  }));
}

const { slug } = Astro.params;
const product = productData.products.find(p => p.slug === slug) || null;

if (!product) {
  return Astro.redirect('/404');
}
---

<Layout 
  title={`${product.name} - Weiyijie Bio`}
  description={`${product.name} supplier. High quality with full certifications, small MOQ supported, fast global delivery. Request a free quote today!`}
>
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- 产品图片 -->
        <div>
          <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <img 
              src={product.image} 
              alt={product.name} 
              class="w-full h-[400px] object-cover"
              onError={(e) => e.target.src = 'https://placehold.co/600x400/f8fafc/1e40af?text=WEIYIJIE+BIO+Product'}
            />
          </div>
        </div>
        <!-- 产品信息 -->
        <div>
          <h1 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-gray-900 mb-4">{product.name}</h1>
          <div class="flex items-center gap-4 mb-6">
            <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">In Stock</span>
            <span class="text-yellow-400 text-lg">⭐⭐⭐⭐⭐ (4.9/5 from 200+ customers)</span>
          </div>
          <p class="text-gray-600 mb-8 text-lg">{product.description}</p>
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-gray-100 rounded-lg p-4">
              <p class="text-sm text-gray-500 mb-1">MOQ</p>
              <p class="font-bold text-gray-900">1kg</p>
            </div>
            <div class="bg-gray-100 rounded-lg p-4">
              <p class="text-sm text-gray-500 mb-1">Lead Time</p>
              <p class="font-bold text-gray-900">3-5 days</p>
            </div>
            <div class="bg-gray-100 rounded-lg p-4">
              <p class="text-sm text-gray-500 mb-1">Shelf Life</p>
              <p class="font-bold text-gray-900">2 Years</p>
            </div>
            <div class="bg-gray-100 rounded-lg p-4">
              <p class="text-sm text-gray-500 mb-1">Certifications</p>
              <p class="font-bold text-gray-900">FDA/REACH/GMP/Kosher/Halal</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/#contact" class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg transition-all transform hover:scale-105 flex-1 text-center">
              Request Free Quote
            </a>
            <a href="/#contact" class="bg-white border-2 border-green-500 hover:bg-green-50 text-green-600 font-semibold px-8 py-3 rounded-lg transition-all transform hover:scale-105 flex-1 text-center">
              Request Free Sample
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 产品详情 -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="border-b border-gray-200 mb-8">
        <nav class="flex gap-8" id="productTabs">
          <button class="tab-btn font-bold text-green-500 border-b-2 border-green-500 pb-4" data-tab="specifications">Specifications</button>
          <button class="tab-btn font-medium text-gray-500 hover:text-gray-900 pb-4" data-tab="applications">Applications</button>
          <button class="tab-btn font-medium text-gray-500 hover:text-gray-900 pb-4" data-tab="packaging">Packaging & Storage</button>
          <button class="tab-btn font-medium text-gray-500 hover:text-gray-900 pb-4" data-tab="certifications">Certifications</button>
        </nav>
      </div>

      <!-- 标签内容块 -->
      <div class="tab-content" id="specifications-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Technical Specifications</h3>
            <table class="w-full">
              {product.specifications.map((spec, index) => {
                // 拆分规格项为键值对
                const parts = spec.split(/:|：|-|–/).map(s => s.trim());
                const key = parts[0] || `Specification ${index + 1}`;
                const value = parts.slice(1).join(': ') || spec;
                return (
                  <tr class="border-b border-gray-200">
                    <td class="py-3 font-medium text-gray-900">{key}</td>
                    <td class="py-3 text-gray-600">{value}</td>
                  </tr>
                );
              })}
            </table>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Parameter Notes</h3>
            <p class="text-gray-600">All parameters are tested and verified by our quality control team, meet international standards. Custom specifications are available upon request.</p>
          </div>
        </div>
      </div>

      <div class="tab-content hidden" id="applications-content">
        <div class="max-w-3xl">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Application Scenarios</h3>
          <ul class="space-y-4">
            {product.applications && product.applications.length > 0 ? (
              product.applications.map(app => (
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">{app}</span>
                </li>
              ))
            ) : product.category === '植物提取物' ? (
              <>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Health supplements: Immune support, antioxidant products</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Cosmetics: Skincare formulations, anti-aging products</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Functional food: Beverages, dietary supplements</span>
                </li>
              </>
            ) : product.category === '化妆品原料' ? (
              <>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Skincare: Creams, serums, masks, lotions</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Cosmetics: Makeup, hair care, personal care products</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Meets all global cosmetic regulatory requirements</span>
                </li>
              </>
            ) : (
              <>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Food & Beverages: Juices, drinks, bakery products</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Health supplements: Nutritional fortifiers, capsules, tablets</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-green-500 mt-1 text-xl">✅</span>
                  <span class="text-gray-700">Meets international food safety standards</span>
                </li>
              </>
            )}
          </ul>
        </div>
      </div>

      <div class="tab-content hidden" id="packaging-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-6">Packaging Options</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">📦</span>
                <span class="text-gray-700">1kg/bag (aluminum foil bag, sealed and moisture-proof)</span>
              </li>
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">📦</span>
                <span class="text-gray-700">25kg/drum (fiber drum, double plastic bag inside)</span>
              </li>
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">📦</span>
                <span class="text-gray-700">Custom packaging available upon request (printing logo, custom size etc.)</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-6">Storage Conditions</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">🌡️</span>
                <span class="text-gray-700">Store in cool, dry place, temperature 0-25°C</span>
              </li>
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">☀️</span>
                <span class="text-gray-700">Away from direct sunlight and strong odors</span>
              </li>
              <li class="flex items-start gap-3 text-lg">
                <span class="text-green-500 mt-1 text-xl">⏳</span>
                <span class="text-gray-700">Shelf life: 2 years when properly stored</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="tab-content hidden" id="certifications-content">
        <div class="max-w-3xl">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Available Certifications</h3>
          <p class="text-gray-700 text-lg mb-8">We can provide full set of certification documents from our cooperative factories, all products meet international quality standards:</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {product.certifications.map(cert => (
              <div class="bg-gray-50 rounded-lg p-6 text-center">
                <span class="block text-2xl mb-2">📜</span>
                <span class="text-gray-900 font-medium">{cert}</span>
              </div>
            ))}
          </div>
          <p class="text-gray-600 mt-8">All certificates are verifiable, contact us for full copies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 标签切换脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabContents = document.querySelectorAll('.tab-content');
      
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetTab = btn.getAttribute('data-tab');
          
          // 切换按钮激活状态
          tabBtns.forEach(b => {
            b.classList.remove('font-bold', 'text-green-500', 'border-b-2', 'border-green-500');
            b.classList.add('font-medium', 'text-gray-500');
          });
          btn.classList.add('font-bold', 'text-green-500', 'border-b-2', 'border-green-500');
          btn.classList.remove('font-medium', 'text-gray-500');
          
          // 切换内容显示
          tabContents.forEach(content => {
            content.classList.add('hidden');
          });
          document.getElementById(`${targetTab}-content`).classList.remove('hidden');
        });
      });
    });
  </script>
    </div>
  </section>

  <!-- 相关产品 -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Related Products You May Be Interested In</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {productData.products
          .filter(p => p.category === product.category && p.id !== product.id)
          .slice(0, 3)
          .map(relatedProduct => (
            <a href={`/product/${relatedProduct.slug}`} class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all group overflow-hidden">
              <div class="h-48 overflow-hidden">
                <img 
                  src={relatedProduct.image} 
                  alt={relatedProduct.name} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
                  onError={(e) => e.target.src = 'https://placehold.co/600x400/f8fafc/1e40af?text=WEIYIJIE+BIO+Product'}
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2">{relatedProduct.name}</h3>
                <p class="text-gray-600 mb-4 line-clamp-3">{relatedProduct.description}</p>
                <span class="text-green-500 font-semibold group-hover:translate-x-2 inline-block transition-all">View Details →</span>
              </div>
            </a>
          ))}
      </div>
    </div>
  </section>
</Layout>
