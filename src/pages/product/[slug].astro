// 静态生成所有产品页面
export async function getStaticPaths() {
  const slugs = [
    "grape-seed-extract-95-proanthocyanidins",
    "organic-astragalus-root-extract",
    "milk-thistle-extract-powder",
    "pure-shilajit-extract",
    "ginseng-extract",
    "natural-grapefruit-powder",
    "cranberry-fruit-powder",
    "mango-fruit-powder",
    "non-irradiated-mango-powder",
    "strawberry-powder",
    "watermelon-powder",
    "organic-milk-thistle-extract",
    "ginkgo-biloba-extract",
    "sea-buckthorn-powder",
    "wheat-grass-powder",
    "hyaluronic-acid-powder",
    "kojic-acid-dipalmitate",
    "alpha-arbutin",
    "retinol",
    "niacinamide",
    "ceramide-complex",
    "natural-vitamin-c",
    "stevia-extract",
    "xanthan-gum",
    "citric-acid",
    "beta-carotene",
    "sodium-erythorbate"
  ];
  return slugs.map(slug => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;
const product = products[slug] || null;

if (!product) {
  return Astro.redirect('/404');
}
